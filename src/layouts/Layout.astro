---
import "../styles/global.css";

const { title = "みやびの日常" } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
    />

    <title>{title}</title>

    <style>
      :root {
        font-family:
          "Hiragino Sans",
          "Yu Gothic",
          sans-serif;
      }
    </style>
  </head>

  <body class="bg-white text-zinc-900 min-h-screen">

    <!-- ヘッダー -->
    <header
      class="
        h-20
        border-b
        border-emerald-400
        bg-emerald-300
        sticky
        top-0
        backdrop-blur
        z-50
      "
    >

      <div
        class="
          max-w-2xl
          mx-auto
          h-full
          flex
          items-center
          justify-between
        "
      >

        <!-- サイトタイトル -->
        <a
          href={import.meta.env.BASE_URL}
          class="
            h-full
            flex
            items-center

            text-2xl
            font-bold

            px-6

            bg-emerald-500
            border-x
            border-emerald-600

            hover:bg-emerald-400
            transition

            text-white
          "
        >
          みやびの日常
        </a>

        <!-- ナビゲーション -->
        <nav
          class="
            flex
            gap-6
            text-sm
            text-emerald-900
            px-8
          "
        >

          <a
            href={`${import.meta.env.BASE_URL}/blog`}
            class="
              hover:text-emerald-700
              transition
            "
          >
            日記
          </a>

          <a
            href={`${import.meta.env.BASE_URL}/favorites`}
            class="
              hover:text-emerald-700
              transition
            "
          >
            好きなもの
          </a>

        </nav>

      </div>

    </header>

    <!-- メイン -->
    <main class="max-w-2xl mx-auto p-8">

      <slot />

    </main>

    <!-- フッター -->
    <footer
      class="
        border-t
        border-zinc-300
        mt-20
      "
    >

      <div
        class="
          max-w-2xl
          mx-auto
          px-8
          py-6
        "
      >

        <p class="text-zinc-600 text-sm">
          © 2026 Miyabi_Akatsuki
        </p>

      </div>

    </footer>

  </body>
</html>