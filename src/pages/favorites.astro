---
import Layout from "../layouts/Layout.astro";
---

<Layout title="好きなもの">

  <h1 class="text-4xl font-bold mb-8">
    好きなもの
  </h1>

  <div class="space-y-4">

    <a
      href={`${import.meta.env.BASE_URL}favorites/music`}
      class="
        block
        border
        border-zinc-300
        rounded-2xl
        p-4
        hover:bg-zinc-100
        transition
      "
    >
      好きな音楽
    </a>

    <a
      href={`${import.meta.env.BASE_URL}favorites/vtuber`}
      class="
        block
        border
        border-zinc-300
        rounded-2xl
        p-4
        hover:bg-zinc-100
        transition
      "
    >
      Vtuber
    </a>

  </div>

</Layout>