---
import Layout from "../../layouts/Layout.astro";

const musics = [
  {
    title: "ガラクタロード",
    artist: "初星学園",
    tags: ["アゲ", "アイマス", "original"],

    comment:
      "メ組のメ！",

    youtube: "O9oCfxSJXTY",
  },

  {
    title: "バース・デイ",
    artist: "浮遊信号",
    tags: ["アゲ", "original"],

    comment:
      "🎂",

    youtube: "QqNPP0shiYQ",
  },
];

//タイトル順ソート
musics.sort((a,b) =>
  a.title.localeCompare(b.title, "ja")
);
---

<Layout title="好きな音楽">

  <h1 class="text-4xl font-bold mb-10">
    音楽
  </h1>

  <p class="text-zinc-700 mb-10">
    お気に入り曲たち。
  </p>

  <div class="space-y-10">

    {
      musics.map((music) => (

        <section
          class="
            border
            border-emerald-300
            bg-emerald-50
            rounded-2xl
            p-6
          "
        >

          <!-- 曲名 -->
          <h2 class="text-2xl font-bold mb-2">
            {music.title}
          </h2>

          <!-- アーティスト -->
          <p class="text-zinc-700 mb-4">
            {music.artist}
          </p>

          <!-- タグ -->
          <div class="flex gap-2 flex-wrap mb-6">

            {
              music.tags.map((tag) => (

                <span
                  class="
                    text-sm
                    bg-emerald-200
                    text-emerald-900
                    px-3
                    py-1
                    rounded-full
                  "
                >
                  #{tag}
                </span>

              ))
            }
          </div>

          <!-- コメント -->
          <p class="text-zinc-800 mb-6 leading-relaxed">
            {music.comment}
          </p>

          <!-- YouTube -->
          <div class="aspect-video">

            <iframe
              class="w-full h-full rounded-xl"
              src={`https://www.youtube.com/embed/${music.youtube}`}
              title={music.title}
              frameborder="0"
              allowfullscreen
            ></iframe>

          </div>

        </section>

      ))
    }
  </div>

</Layout>