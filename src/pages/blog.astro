---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<Layout title="日記">

  <h1 class="text-4xl font-bold mb-8">
    日記
  </h1>

  <ul class="space-y-4">

    {
      posts.map((post) => (
        <li class="border border-zinc-800 rounded-2xl p-4">

          <p class="text-zinc-500 text-sm mb-2">
            {post.data.date.toLocaleDateString("ja-JP")}
          </p>

          <a
            href={`${import.meta.env.BASE_URL}/blog/${post.id}`}
            class="text-xl hover:text-zinc-400 transition"
          >
            {post.data.title}
          </a>

        </li>
      ))
    }

  </ul>

</Layout>